# ─────────────────────────────────────────────────────────────────
#  SF Agentic AI — Settings File
#  Copy this file to .env and fill in your values
#  Run:  cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# LM Studio server address
# Default is http://localhost:1234/v1 — only change if you moved it
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# LLM provider selector:
# - lm_studio (default) — local LM Studio, no API key needed
# - anthropic           — Anthropic Claude with prompt caching (requires ANTHROPIC_API_KEY)
# - hermes              — Hermes gateway runtime
LLM_PROVIDER=lm_studio

# ─────────────────────────────────────────────────────────────────
# Anthropic Settings (only used when LLM_PROVIDER=anthropic)
# ─────────────────────────────────────────────────────────────────

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model cascade — each agent uses the right model for its task complexity.
# Defaults below reflect the recommended cost/quality balance.
# Only override if you want to force a specific tier for an agent.
#
#  claude-haiku-4-20250514   — fastest, cheapest   → extraction & JSON tasks
#  claude-sonnet-4-5         — balanced             → analysis & compliance
#  claude-opus-4-5           — most capable         → final memo & gatekeeper
#
# AGENT_MODEL_*:
ANTHROPIC_MODEL_INGESTION=claude-haiku-4-20250514
ANTHROPIC_MODEL_MARKET_INTEL=claude-haiku-4-20250514
ANTHROPIC_MODEL_FINANCIAL=claude-sonnet-4-5
ANTHROPIC_MODEL_COMPLIANCE=claude-sonnet-4-5
ANTHROPIC_MODEL_DISTRIBUTION=claude-sonnet-4-5
ANTHROPIC_MODEL_OPERATIONS=claude-sonnet-4-5
ANTHROPIC_MODEL_MEMO=claude-opus-4-5
ANTHROPIC_MODEL_ADVISOR=claude-opus-4-5

# Fallback model if an agent isn't in the map above
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional non-interactive mode for unattended runs:
# - true  => no input prompts, auto-approve gate when unspecified
# - false => interactive prompts allowed
SF_AUTONOMOUS_MODE=false

# The exact model name as it appears in LM Studio
# Run: curl http://localhost:1234/v1/models to see exact IDs
#
# M5 32GB recommended models and their context limits:
#   qwen3.5-9b                →  128K context, fastest, best for iteration
#   qwen/qwen3.6-35b-a3b      →   32K context, MoE 35B, strongest reasoning
#   google/gemma-4-26b-a4b    →   64K context, MoE 26B, good balance
#   google/gemma-4-31b        →   64K context, dense 31B, most capable
LM_STUDIO_MODEL=qwen3.5-9b

# LM Studio doesn't need a real API key, but the OpenAI library requires one
# Leave this as-is
LM_STUDIO_API_KEY=lm-studio

# Hermes gateway settings (used when LLM_PROVIDER=hermes)
HERMES_BASE_URL=http://127.0.0.1:18789
HERMES_API_KEY=hermes
HERMES_MODEL=lmstudio/qwen/qwen3.5-9b

# How creative/deterministic the model should be (0.0 = focused, 1.0 = creative)
# For financial/legal work, keep this low
LLM_TEMPERATURE=0.1

# Maximum tokens the model can generate per response
# IMPORTANT: All loaded models use extended thinking/reasoning mode.
# Thinking consumes ~500–2000 tokens BEFORE output starts.
# Minimum 4096; use 8192 for complex financial analysis and long memos.
LLM_MAX_TOKENS=8192

# Per-request LLM timeout in seconds.
# Keep low for predictable latency in local mode.
LLM_TIMEOUT_SEC=35

# OpenAI-python retry count for LM Studio/Hermes-compatible endpoints.
# 0 disables hidden retry loops and prevents 3x timeout behavior.
LLM_MAX_RETRIES=0

# Max graph steps before hard-stop (prevents runaway routing loops)
PIPELINE_RECURSION_LIMIT=40

# Path to your local ChromaDB database
CHROMA_DB_PATH=./data/chroma_db

# Path to the knowledge base folder (SBV circulars, deal templates, etc.)
KNOWLEDGE_BASE_PATH=./data/knowledge_base

# Web research (Perplexity)
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar
ENABLE_WEB_RESEARCH=false
PERPLEXITY_TIMEOUT_SEC=45

# ─────────────────────────────────────────────────────────────────
#  Autonomous Inbox Worker (drop files, auto-run in background)
# ─────────────────────────────────────────────────────────────────
# Set to a local folder OR a Google Drive synced local folder.
SF_INBOX_DIR=./data/inbox/pending
SF_PROCESSING_DIR=./data/inbox/processing
SF_ARCHIVE_DIR=./data/inbox/archive
SF_FAILED_DIR=./data/inbox/failed
SF_CONTROL_DIR=./data/inbox/control
SF_POLL_SEC=15
SF_INBOX_MAX_FILES=20

# Trigger mode:
# - auto   => run automatically when new files appear
# - marker => run only when SF_TRIGGER_FILE exists
SF_TRIGGER_MODE=auto
SF_TRIGGER_FILE=./data/inbox/TRIGGER

# Runtime profile for background worker
SF_PROVIDER=hermes
SF_POST_CREDIT_MODE=stop
SF_HUMAN_GATE=approve
SF_ROUTE_MODE=auto
SF_FORCE_AUTONOMOUS=true
SF_FORCE_FAST=true
SF_SKIP_PREFLIGHT=false
SF_RUN_TIMEOUT_SEC=1800
SF_NO_WEB_RESEARCH=false

# Optional status notifications from inbox worker
# Example:
# SF_NOTIFY_CHANNEL=telegram
# SF_NOTIFY_TARGET=@your_username_or_chat_id
SF_NOTIFY_CHANNEL=
SF_NOTIFY_TARGET=

# ─────────────────────────────────────────────────────────────────
#  Backend UI/API hosting
# ─────────────────────────────────────────────────────────────────
# Comma-separated allowed browser origins for CORS.
# Use "*" for local single-origin hosting, or explicit origins for remote setup.
SF_UI_ORIGINS=*

# Optional API key guard for all /api/* routes.
# When set, clients must send header: X-SF-API-KEY: <value>
SF_API_KEY=
