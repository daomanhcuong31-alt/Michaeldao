# ─────────────────────────────────────────────────────────────────
#  SF Agentic AI — Active Settings (MacBook Pro M5 32GB)
# ─────────────────────────────────────────────────────────────────

# LM Studio server
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Active model — swap to any of the options below
LM_STUDIO_MODEL=qwen3.5-9b

# ── Available models (copy exact ID into LM_STUDIO_MODEL above) ──
# qwen3.5-9b                 → fastest, 128K context, best for iteration
# qwen/qwen3.6-35b-a3b       → MoE 35B, 32K context, strongest reasoning
# google/gemma-4-26b-a4b     → MoE 26B, 64K context, good balance
# google/gemma-4-31b         → dense 31B, 64K context, most capable

# Model behaviour
# NOTE: All loaded models use extended thinking/reasoning mode.
# max_tokens must be high enough to cover reasoning tokens (~500–2000)
# PLUS your actual output. 8192 is the safe minimum for complex work.
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192

# Storage paths
CHROMA_DB_PATH=./data/chroma_db
KNOWLEDGE_BASE_PATH=./data/knowledge_base
